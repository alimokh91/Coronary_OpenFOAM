// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    object          fvSolution;
}

solvers
{
    p
    {
        solver          GAMG;
        tolerance       1e-07;
        relTol          0.05;
        smoother        DICGaussSeidel;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }
    pFinal
    {
        solver          GAMG;
        tolerance       1e-09;
        relTol          0;
        smoother        DICGaussSeidel;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }
    "(U|k|omega)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-08;
        relTol          0.1;
    }
    "(U|k|omega)Final"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-10;
        relTol          0;
    }
    Phi
    {
        solver          GAMG;
        tolerance       1e-07;
        relTol          0.05;
        smoother        DICGaussSeidel;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     1;
    }
}

potentialFlow
{
    nNonOrthogonalCorrectors 0;
}

PIMPLE
{
    nOuterCorrectors 40;
    nCorrectors     2;
    nNonOrthogonalCorrectors 1;
    momentumPredictor yes;
    pRefCell        0;
    pRefValue       0;
    residualControl
    {
        p
        {
            tolerance       0.0001;
            relTol          0;
        }
        U
        {
            tolerance       0.0001;
            relTol          0;
        }
    }
}

relaxationFactors
{
    fields
    {
        p               0.3;
        pFinal          1;
    }
    equations
    {
        U               0.7;
        UFinal          1;
    }
}


